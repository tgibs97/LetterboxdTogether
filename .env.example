TMDB_API_KEY=your_tmdb_api_key_here
# TMDB_BEARER_TOKEN=your_tmdb_read_access_token_here

# Optional server settings
# PORT=3000

# Optional Letterboxd scraping settings
# LETTERBOXD_REQUEST_DELAY_MS=3000
# Set to 0 for all pages. Set to 1 if you only want the first page.
# LETTERBOXD_MAX_DIARY_PAGES=0
# LETTERBOXD_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
# LETTERBOXD_COOKIE=copy_your_browser_cookie_here

# Cloudflare Tunnel token — generated in the Zero Trust dashboard
# See DEPLOY.md for setup instructions
# CLOUDFLARE_TUNNEL_TOKEN=
